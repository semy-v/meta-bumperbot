[Unit]
Description=ROS2 state publisher service of bumperbot description
PartOf=bumperbot.target
After=network.target
StartLimitIntervalSec=20
StartLimitBurst=3

[Service]
Type=simple
User=root
Group=root
EnvironmentFile=-/run/bumperbot.env
ExecStartPre=/opt/ros/jazzy/share/bumperbot_bringup/scripts/run_env_setup.sh
ExecStart=/opt/ros/jazzy/bin/ros2 launch bumperbot_description robot_state_publisher.launch.py is_sim:=false
Restart=on-failure
RestartSec=5s

[Install]
RequiredBy=bumperbot.target
