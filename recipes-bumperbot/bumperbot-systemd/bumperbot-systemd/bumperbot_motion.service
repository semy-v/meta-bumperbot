[Unit]
Description=Bumperbot motion planner
PartOf=bumperbot.target
After=bumperbot_localization.service
BindsTo=bumperbot_localization.service
StartLimitIntervalSec=20
StartLimitBurst=3

[Service]
Type=simple
User=root
Group=root
EnvironmentFile=-/run/bumperbot.env
ExecStartPre=/opt/ros/jazzy/share/bumperbot_bringup/scripts/run_env_setup.sh
ExecStart=/opt/ros/jazzy/bin/ros2 launch bumperbot_motion motion_server.launch.py
Restart=on-failure
RestartSec=5s

[Install]
RequiredBy=bumperbot.target
